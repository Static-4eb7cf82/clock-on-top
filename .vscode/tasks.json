{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "check: frontend build",
            "type": "shell",
            "options": {
                "cwd": "app"
            },
            "command": "npm run build",
            "problemMatcher": [
                "$tsc"
            ],
            "group": "build"
        },
        {
            "label": "check: tauri cargo",
            "type": "shell",
            "options": {
                "cwd": "app/src-tauri"
            },
            "command": "cargo check",
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build"
        },
        {
            "label": "check: all builds",
            "dependsOrder": "sequence",
            "dependsOn": [
                "check: frontend build",
                "check: tauri cargo"
            ],
            "problemMatcher": []
        },
        {
            "label": "run dev",
            "type": "shell",
            "options": {
                "cwd": "app"
            },
            "command": "npm run tauri dev",
            "problemMatcher": []
        },
        {
            "label": "Version Bump",
            "type": "shell",
            "command": "npm run version-bump ${input:versionString}",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always"
            }
        }
    ],
    "inputs": [
        {
            "id": "versionString",
            "type": "promptString",
            "description": "Enter new version (e.g. 1.2.3)",
            "default": ""
        }
    ]
}