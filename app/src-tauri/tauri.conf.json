{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clock On Top",
  "version": "0.4.0",
  "identifier": "com.static-4eb7cf82.clock-on-top",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clock On Top",
        "url": "index.html",
        "fullscreen": false,
        "width": 50,
        "height": 50,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "resizable": false,
        "alwaysOnTop": true
      },
      {
        "label": "settings",
        "title": "Clock Settings",
        "url": "settings.html",
        "visible": false,
        "width": 650,
        "height": 600,
        "transparent": false,
        "decorations": false,
        "shadow": true,
        "resizable": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": [
      "icons/32x32.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
