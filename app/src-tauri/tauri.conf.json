{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clock On Top",
  "version": "0.8.1",
  "identifier": "com.static-4eb7cf82.clock-on-top",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "clock",
        "title": "Clock On Top",
        "url": "index.html",
        "visible": false,
        "fullscreen": false,
        "width": 50,
        "height": 50,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "index.html",
        "create": false,
        "visible": false,
        "width": 900,
        "height": 600,
        "transparent": false,
        "decorations": true,
        "shadow": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "about",
        "title": "About",
        "url": "index.html",
        "create": false,
        "visible": false,
        "width": 550,
        "height": 350,
        "transparent": false,
        "decorations": true,
        "shadow": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "nsis",
    "resources": {
      "icons/32x32.png": "icons/32x32.png",
      "../../LICENSE": "LICENSE"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFMEQyMUY1NjgzNDE2NkEKUldScUZqUm85U0VObmtzRHpLOHVRdDhDRGFJaWo2MFVjYzNWRVRORHNnNjZRNlFjaGwrbGdXdTIK",
      "endpoints": [
        "https://github.com/static-4eb7cf82/clock-on-top/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
